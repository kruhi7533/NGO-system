# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-random-secret-at-least-32-chars"

# ─── Email (verification + password reset) ───────────────────────────────────
# If NEITHER provider below is configured, emails are logged to the server
# console instead of being sent (dev mode) — the app still works locally.
#
# Option A: Resend (recommended — no SMTP setup, sent over HTTPS)
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="Imparency <noreply@yourdomain.com>"

# Option B: SMTP / Nodemailer (used only if RESEND_API_KEY is unset)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"            # 465 = implicit TLS, 587 = STARTTLS
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── App URLs ─────────────────────────────────────────────────────────────────
VITE_CLIENT_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3001"
API_PORT="3001"
